      "help": "Affects customization: company rubric.",
      "affects": [
        "prompt",
        "validation",
        "workflow",
        "export"
      ],
      "default": ""
    },
    {
      "key": "review_cycle",
      "label": "review cycle",
      "type": "text",
      "required": false,
      "help": "Affects customization: review cycle.",
      "affects": [
        "prompt",
        "validation",
        "workflow",
        "export"
      ],
      "default": ""
