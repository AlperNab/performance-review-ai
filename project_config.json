{
  "slug": "performance-review-ai",
  "name": "Performance Review Ai",
  "domain": "HR / Performance",
  "target_user": "Domain operator, business owner, analyst, or team member who needs this workflow executed reliably.",
  "core_job": "Feedback notes → performance review",
  "deep_features": [
    "evidence mapping",
    "rating calibration",
    "SMART goals",
    "bias language check",
    "promotion readiness",
    "development plan",
    "manager coaching notes"
  ],
  "input_schema": [
    {
      "key": "feedback_notes",
      "label": "Feedback notes",
      "type": "textarea",
      "required": true,
      "help": "Affects input: Feedback notes.",
      "affects": [
        "prompt",
        "workflow"
      ],
      "default": ""
    },
    {
      "key": "work_brief",
      "label": "Work brief / source text / URL / instructions",
      "type": "textarea",
      "required": true,
      "default": "",
      "help": "Paste the material, URL, description, or instruction needed for this project.",
      "affects": [
        "prompt",
        "workflow"
      ]
    }
  ],
  "customization_schema": [
    {
      "key": "execution_mode",
      "label": "Execution mode",
      "type": "select",
      "required": false,
      "options": [
        "Draft",
        "Production",
        "Audit / strict review",
        "JSON/API output"
      ],
      "default": "Production",
      "help": "Controls strictness, depth, and output format for this project workflow.",
      "affects": [
        "workflow",
        "validation",
        "export"
      ]
    },
    {
      "key": "company_rubric",
      "label": "company rubric",
      "type": "text",
